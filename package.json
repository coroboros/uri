{
  "name": "@coroboros/uri",
  "version": "1.0.0",
  "description": "RFC-3986 compliant, zero-dependency URI toolkit for Node.js.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "keywords": [
    "coroboros",
    "uri",
    "url",
    "rfc-3986",
    "parse",
    "encode",
    "decode",
    "validate",
    "sitemap",
    "punycode",
    "ip",
    "domain",
    "typescript",
    "nodejs"
  ],
  "author": "Coroboros <ob@coroboros.com> (https://github.com/coroboros)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coroboros/uri.git"
  },
  "bugs": {
    "url": "https://github.com/coroboros/uri/issues"
  },
  "homepage": "https://github.com/coroboros/uri#readme",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.1.3",
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "preferGlobal": false,
  "analyze": false,
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
